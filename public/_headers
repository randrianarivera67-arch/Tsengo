# Cloudflare Pages — en-tetes personnalises

# Service workers : autorises a controler toute l'origine (equivalent
# du "Service-Worker-Allowed" qui etait dans vercel.json)
/OneSignalSDKWorker.js
  Service-Worker-Allowed: /
  Cache-Control: no-cache

/firebase-messaging-sw.js
  Service-Worker-Allowed: /
  Cache-Control: no-cache

# Verification Android (TWA mg.tsengo.app)
/.well-known/assetlinks.json
  Content-Type: application/json
  Access-Control-Allow-Origin: *
