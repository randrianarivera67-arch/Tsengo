# ── Firebase ─────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Telegram Bot Storage (IMAGE + AUDIO seulement) ───────────────────────
VITE_TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHI...
VITE_TELEGRAM_CHAT_ID=-1001234567890

# ── YouTube Storage (VIDEO) ───────────────────────────────────────────────
# 1. Google Cloud Console → "Tsengo" OAuth2 client → copier Client ID + Secret
# 2. Ajouter Authorized redirect URI: https://votre-app.vercel.app/oauth/callback
# 3. Activer "YouTube Data API v3" dans APIs & Services
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=https://votre-app.vercel.app/oauth/callback

# ── Backend (Render) ─────────────────────────────
VITE_BACKEND_URL=https://tsengo-backend.onrender.com
VITE_NOTIFY_SECRET=your_secret_here

# ── OneSignal ────────────────────────────────────
VITE_ONESIGNAL_APP_ID=your_onesignal_app_id
